{
  "name": "redix-app",
  "productName": "Redix",
  "version": "0.0.1",
  "description": "Redix — A modern Redis desktop client built with Tauri, React & TypeScript",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --config vite.config.ts --host 127.0.0.1",
    "build": "tauri build --bundles app",
    "build:dmg": "tauri build --bundles dmg",
    "build:web": "vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "verify:macos": "scripts/verify-macos-release.sh",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:web",
    "check": "npm run typecheck && cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "keywords": [
    "redis",
    "tauri",
    "desktop"
  ],
  "author": "Redix contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qIsaac/Redix.git"
  },
  "bugs": {
    "url": "https://github.com/qIsaac/Redix/issues"
  },
  "homepage": "https://github.com/qIsaac/Redix#readme",
  "devDependencies": {
    "@radix-ui/react-context-menu": "^2.3.2",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-window": "^2.2.7",
    "typescript": "^7.0.2",
    "vite": "^6.4.3",
    "zustand": "^5.0.14"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.0.0"
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Redix",
  "version": "0.0.1",
  "identifier": "com.redix.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist-web"
  },
  "app": {
    "windows": [
      {
        "title": "Redix",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "icon": ["../resources/icon.icns", "../resources/icon.png"]
  }
}
